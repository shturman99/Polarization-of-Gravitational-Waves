(* H_ijij integral evaluation (Mathematica/Wolfram Language) *)

(* === Definitions matching LaTeX draft === *)
ClearAll[eta, ESpec, gSpec, uSpec, kernelK, muIntClosedForm, Hijij];

(* Options and defaults for the main integral *)
Options[Hijij] = {
  Ck -> 1,
  eps -> 1,
  k1Max -> 20,
  om1Max -> 20,
  uReg -> 0,
  wp -> 40,
  ag -> 8,
  pg -> 8,
  mr -> 15,
  useAnalyticMu -> True
};

(* eta(k) and E(k) from the draft *)
eta[k_, eps_] := (1/Sqrt[2*Pi]) * eps^(1/3) * k^(2/3);
ESpec[k_, Ck_, eps_] := Ck * eps^(2/3) * k^(-5/3);

(* g(k, ω) from the draft (evaluated at (k1, ω1) and (u, ω-ω1)) *)
gSpec[k_, om_, Ck_, eps_] := (2*ESpec[k, Ck, eps])/(k^2*eta[k, eps]) * Exp[-om^2/(Pi*eta[k, eps]^2)];

(* u(k,k1,μ) from the draft, with optional regularization uReg *)
uSpec[k_, k1_, mu_, uReg_] := Sqrt[k^2 + k1^2 - 2*k*k1*mu + uReg^2];

(* Kernel K(k,k1,u) from the draft *)
kernelK[k_, k1_, u_] := 27/6 + k^4/(12*k1^2*u^2) + k1^2/(12*u^2) + u^2/(12*k1^2)
  - k^2/(6*u^2) - k^2/(6*k1^2);

(* Analytic μ-integral helper (for inspection only). Does not force use inside NIntegrate. *)
muIntClosedForm[k_, k1_, om_, om1_, opts : OptionsPattern[Hijij]] := Module[
  {CkVal = OptionValue[Ck], epsVal = OptionValue[eps], uRegVal = OptionValue[uReg], mu},
  Integrate[
    kernelK[k, k1, uSpec[k, k1, mu, uRegVal]]
      * gSpec[k1, om1, CkVal, epsVal]
      * gSpec[uSpec[k, k1, mu, uRegVal], om - om1, CkVal, epsVal],
    {mu, -1, 1}
  ]
];

(* === Main callable: H_ijij === *)
Hijij[k_?NumericQ, om_?NumericQ, opts : OptionsPattern[]] := Module[
  {
    CkVal = OptionValue[Ck],
    epsVal = OptionValue[eps],
    k1MaxVal = OptionValue[k1Max],
    om1MaxVal = OptionValue[om1Max],
    uRegVal = OptionValue[uReg],
    wpVal = OptionValue[wp],
    agVal = OptionValue[ag],
    pgVal = OptionValue[pg],
    mrVal = OptionValue[mr],
    useAnalyticMuVal = OptionValue[useAnalyticMu],
    pref, muClosed, k1, mu, om1, nintOpts, k1Range, om1Range, muIntegrand
  },

  (* Post-phi prefactor: ∫ dφ = 2π *)
  pref = 1/(2*Pi)^7;

  (* Integration ranges for k1 and ω1 (finite cutoffs by default) *)
  k1Range = {k1, 0, k1MaxVal};
  om1Range = {om1, -om1MaxVal, om1MaxVal};

  (* NIntegrate configuration for stability *)
  nintOpts = {
    Method -> {"GlobalAdaptive", "SymbolicProcessing" -> 0},
    WorkingPrecision -> wpVal,
    AccuracyGoal -> agVal,
    PrecisionGoal -> pgVal,
    MaxRecursion -> mrVal,
    Exclusions -> {k^2 + k1^2 - 2*k*k1*mu == 0}
  };

  (* μ integrand with measure factor k1^2, matching the draft *)
  muIntegrand[k1_?NumericQ, mu_?NumericQ, om1_?NumericQ] := Module[
    {uVal = uSpec[k, k1, mu, uRegVal]},
    pref * k1^2 * kernelK[k, k1, uVal]
      * gSpec[k1, om1, CkVal, epsVal]
      * gSpec[uVal, om - om1, CkVal, epsVal]
  ];

  (* Try analytic μ integral if requested and closed-form is found *)
  If[TrueQ[useAnalyticMuVal],
    muClosed = muIntClosedForm[k, k1, om, om1, Ck -> CkVal, eps -> epsVal, uReg -> uRegVal];
    If[FreeQ[muClosed, Integrate],
      Return[
        NIntegrate[
          pref * k1^2 * muClosed,
          k1Range,
          om1Range,
          Evaluate[Sequence @@ nintOpts]
        ]
      ];
    ];
  ];

  (* Full numeric integral over k1, μ, ω1 if analytic μ is unavailable *)
  NIntegrate[
    muIntegrand[k1, mu, om1],
    k1Range,
    {mu, -1, 1},
    om1Range,
    Evaluate[Sequence @@ nintOpts]
  ]
];

(* === Smoke tests === *)
Print[Hijij[1., 0.5]];
Print[Hijij[1., 0.5, k1Max -> 10, om1Max -> 10]];
