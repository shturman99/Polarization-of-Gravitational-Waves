(* =========================================================*)
(* H_ijij integral evaluation (Wolfram Language) *)
(* Modular + interactive diagnostics *)
(* Matches LaTeX draft: prefactor (2\[Pi])^(-7), measure k1^2 *)
(* =========================================================*)
ClearAll["Global`*"];

(* ---------- Option declarations ---------- *)
Options[Hijij] = {
  Ck -> 1,
  eps -> 1,
  k1Max -> 20,
  om1Max -> 20,
  uReg -> 0,
  wp -> 40,
  ag -> 8,
  pg -> 8,
  mr -> 15,
  useAnalyticMu -> True,
  diagnostics -> False,
  (* progress reporting *)
  progressEnabled -> True,
  progressPrintStep -> 0.01, (* percent *)
  progressTarget -> 1000000, (* base count for 100% *)
  progressMaxPrints -> Infinity
};

(* ---------- Physics definitions (pure functions) ---------- *)
eta[k_, eps_] := (1/Sqrt[2 Pi]) eps^(1/3) k^(2/3);
ESpec[k_, Ck_, eps_] := Ck eps^(2/3) k^(-5/3);

gSpec[k_, om_, Ck_, eps_] := (2 ESpec[k, Ck, eps])/(k^2 eta[k, eps])*
  Exp[-om^2/(Pi eta[k, eps]^2)];

uSpec[k_, k1_, mu_, uReg_] := Sqrt[k^2 + k1^2 - 2 k k1 mu + uReg^2];

kernelK[k_, k1_, u_] := 27/6 + k^4/(12 k1^2 u^2) + k1^2/(12 u^2) +
  u^2/(12 k1^2) - k^2/(6 u^2) - k^2/(6 k1^2);

prefactor[] := 1/(2 Pi)^7;

(* ---------- Core building blocks ---------- *)
(* Construct \[Mu]-integrand WITH measure factor k1^2 and overall prefactor (2\[Pi])^(-7) *)
muIntegrandBuilder[k_?NumericQ, om_?NumericQ, CkVal_?NumericQ, epsVal_?NumericQ, uRegVal_?NumericQ] :=
  Function[{k1, mu, om1},
    Module[{uVal = uSpec[k, k1, mu, uRegVal]},
      prefactor[]*k1^2*kernelK[k, k1, uVal]*gSpec[k1, om1, CkVal, epsVal]*
        gSpec[uVal, om - om1, CkVal, epsVal]
    ]
  ];

(* Analytic \[Mu] integral for inspection only; do not auto-force it into numerics unless it truly closes *)
muIntClosedForm[k_, k1_, om_, om1_, CkVal_, epsVal_, uRegVal_] :=
  Module[{mu},
    Integrate[
      kernelK[k, k1, uSpec[k, k1, mu, uRegVal]]*
        gSpec[k1, om1, CkVal, epsVal]*
        gSpec[uSpec[k, k1, mu, uRegVal], om - om1, CkVal, epsVal],
      {mu, -1, 1},
      GenerateConditions -> False
    ]
  ];

muClosedReadyQ[expr_] := FreeQ[expr, Integrate] && FreeQ[expr, ConditionalExpression];

(* NIntegrate options (centralized) *)
nintOptions[wpVal_, agVal_, pgVal_, mrVal_, excl_] := {
  Method -> {"GlobalAdaptive", "SymbolicProcessing" -> 0},
  WorkingPrecision -> wpVal,
  AccuracyGoal -> agVal,
  PrecisionGoal -> pgVal,
  MaxRecursion -> mrVal,
  Exclusions -> excl
};

(* ---------- Diagnostics helpers ---------- *)

sampleReport[k_?NumericQ, om_?NumericQ, CkVal_?NumericQ, epsVal_?NumericQ, uRegVal_?NumericQ, k1MaxVal_?NumericQ, om1MaxVal_?NumericQ] :=
  Module[{f, pts, rows},
    f = muIntegrandBuilder[k, om, CkVal, epsVal, uRegVal];
    pts = {
      {k1MaxVal*0.1, -0.9, 0.0},
      {k1MaxVal*0.3, 0.0, 0.0},
      {k1MaxVal*0.7, 0.5, 0.2 om1MaxVal},
      {k, 0.99, 0.0}, (* near potentially sharp region *)
      {k, 1.0, 0.0}   (* uReg protects this *)
    };
    rows = Table[
      With[{k1 = pts[[i, 1]], mu = pts[[i, 2]], om1 = pts[[i, 3]]},
        {
          i,
          k1,
          mu,
          om1,
          N[uSpec[k, k1, mu, uRegVal]],
          Quiet@Check[N[f[k1, mu, om1]], Indeterminate]
        }
      ],
      {i, Length[pts]}
    ];
    Grid[Prepend[rows, {"#", "k1", "mu", "om1", "u(k,k1,mu)", "integrand"}], Frame -> All]
  ];

(* ---------- Main callable ---------- *)
(* Usage examples: *)
(* Hijij[1., 0.5, progressEnabled -> True, progressPrintStep -> 0.01, progressTarget -> 200000] *)
(* Hijij[1., 0.5, progressEnabled -> False] *)

Hijij[k_?NumericQ, om_?NumericQ, opts : OptionsPattern[]] :=
  Module[
    {
      CkVal = OptionValue[Ck],
      epsVal = OptionValue[eps],
      k1MaxVal = OptionValue[k1Max],
      om1MaxVal = OptionValue[om1Max],
      uRegVal = OptionValue[uReg],
      wpVal = OptionValue[wp],
      agVal = OptionValue[ag],
      pgVal = OptionValue[pg],
      mrVal = OptionValue[mr],
      useAnalyticMuVal = OptionValue[useAnalyticMu],
      diagQ = TrueQ[OptionValue[diagnostics]],
      progressEnabledQ = TrueQ[OptionValue[progressEnabled]],
      progressPrintStepVal = OptionValue[progressPrintStep],
      progressTargetBase = OptionValue[progressTarget],
      progressMaxPrintsVal = OptionValue[progressMaxPrints],
      startTime = AbsoluteTime[],
      tick = 0,
      lastBin = -1,
      prints = 0,
      fMu,
      excl,
      nopts,
      res,
      muClosed,
      muClosedFunc,
      fAnalytic,
      currentK1, currentMu, currentOm1, currentU, currentF,
      progressTargetEff,
      progressReport
    },

    progressPrintStepVal = If[NumericQ[progressPrintStepVal] && progressPrintStepVal > 0, progressPrintStepVal, 0.01];
    progressTargetBase = If[NumericQ[progressTargetBase] && progressTargetBase > 0, progressTargetBase, 1000000];
    progressMaxPrintsVal = If[progressMaxPrintsVal === Infinity || (NumericQ[progressMaxPrintsVal] && progressMaxPrintsVal > 0), progressMaxPrintsVal, Infinity];

    progressReport[k1Val_, muVal_, om1Val_, uVal_, fVal_, estimateVal_] :=
      Module[{percent, bin, muDisplay, uDisplay, estDisplay},
        tick++;
        percent = 100.0*tick/progressTargetEff;
        bin = Floor[percent/progressPrintStepVal];
        If[bin > lastBin && prints < progressMaxPrintsVal,
          lastBin = bin;
          prints++;
          muDisplay = If[NumericQ[muVal], NumberForm[muVal, {6, 4}], muVal];
          uDisplay = If[NumericQ[uVal], NumberForm[uVal, {8, 4}], uVal];
          estDisplay = If[NumericQ[estimateVal], NumberForm[estimateVal, {10, 4}], estimateVal];
          Print[
            Row[{
              NumberForm[Min[percent, 100.], {6, 4}], "%  ",
              "k1=", NumberForm[k1Val, {8, 4}], "  ",
              "mu=", muDisplay, "  ",
              "om1=", NumberForm[om1Val, {8, 4}], "  ",
              "u=", uDisplay, "  ",
              "f=", NumberForm[fVal, {10, 4}], "  ",
              "t=", NumberForm[AbsoluteTime[] - startTime, {8, 2}], "s  ",
              "I=", estDisplay
            }]
          ];
        ];
      ];

    (* Build \[Mu]-integrand *)
    fMu = Function[{k1, mu, om1},
      Module[{uVal, fVal},
        uVal = uSpec[k, k1, mu, uRegVal];
        fVal = prefactor[]*k1^2*kernelK[k, k1, uVal]*gSpec[k1, om1, CkVal, epsVal]*
          gSpec[uVal, om - om1, CkVal, epsVal];
        If[progressEnabledQ,
          currentK1 = k1; currentMu = mu; currentOm1 = om1; currentU = uVal; currentF = fVal;
        ];
        fVal
      ]
    ];

    (* Exclude the unregularized singular surface (u=0) if uReg==0 *)
    excl = If[uRegVal == 0, {k^2 + k1^2 - 2 k k1 mu == 0}, {}];
    nopts = nintOptions[wpVal, agVal, pgVal, mrVal, excl];

    If[diagQ,
      Print["--- Hijij diagnostics ---"];
      Print[Row[{"k=", k, ", om=", om, ", Ck=", CkVal, ", eps=", epsVal, ", uReg=", uRegVal}]];
      Print[Row[{"k1Max=", k1MaxVal, ", om1Max=", om1MaxVal, ", pref=", prefactor[]}]];
      Print["Sample integrand values:"];
      Print[sampleReport[k, om, CkVal, epsVal, uRegVal, k1MaxVal, om1MaxVal]];
    ];

    (* Attempt analytic \[Mu] integration for inspection; only use if really closed *)
    If[useAnalyticMuVal,
      muClosed = muIntClosedForm[k, k1, om, om1, CkVal, epsVal, uRegVal];
      If[diagQ, Print["Analytic \[Mu] integral closed form? ", muClosedReadyQ[muClosed]]];
      If[muClosedReadyQ[muClosed],
        muClosedFunc = Function[{k1, om1}, Evaluate[prefactor[]*k1^2*muClosed]];
        fAnalytic = Function[{k1, om1},
          Module[{fVal},
            fVal = muClosedFunc[k1, om1];
            If[progressEnabledQ,
              currentK1 = k1; currentMu = \"(analytic)\"; currentOm1 = om1; currentU = \"n/a\"; currentF = fVal;
            ];
            fVal
          ]
        ];
        progressTargetEff = Max[
          1,
          Round[progressTargetBase*(1 + mrVal/10.)*(1 + (agVal + pgVal)/20.)*(2/3.)]
        ];
        res = NIntegrate[
          fAnalytic[k1, om1],
          {k1, 0, k1MaxVal},
          {om1, -om1MaxVal, om1MaxVal},
          Evaluate[Sequence @@ nopts],
          EvaluationMonitor :> If[
            progressEnabledQ,
            progressReport[currentK1, "(analytic)", currentOm1, "n/a", currentF, "n/a"]
          ]
        ];
        Return[res];
      ];
    ];

    (* Otherwise do the full numeric triple integral *)
    progressTargetEff = Max[
      1,
      Round[progressTargetBase*(1 + mrVal/10.)*(1 + (agVal + pgVal)/20.)]
    ];
    res = NIntegrate[
      fMu[k1, mu, om1],
      {k1, 0, k1MaxVal},
      {mu, -1, 1},
      {om1, -om1MaxVal, om1MaxVal},
      Evaluate[Sequence @@ nopts],
      EvaluationMonitor :> If[progressEnabledQ, progressReport[currentK1, currentMu, currentOm1, currentU, currentF, "n/a"]]
    ];

    If[diagQ, Print["Result: ", res]];
    res
  ];

(* ---------- Interactive exploration UI ---------- *)

HijijExplorer[] :=
  Manipulate[
    Module[{val},
      val = Hijij[
        k, om,
        Ck -> Ck,
        eps -> eps,
        k1Max -> k1Max,
        om1Max -> om1Max,
        uReg -> uReg,
        wp -> wp,
        ag -> ag,
        pg -> pg,
        mr -> mr,
        useAnalyticMu -> useAnalyticMu,
        diagnostics -> diagnostics,
        progressEnabled -> progressEnabled,
        progressPrintStep -> progressPrintStep,
        progressTarget -> progressTarget,
        progressMaxPrints -> progressMaxPrints
      ];
      Column[
        {
          Style["H_ijij(k, \[Omega]) evaluation", 14, Bold],
          Row[{"H = ", val}],
          If[showSample, sampleReport[k, om, Ck, eps, uReg, k1Max, om1Max], Nothing]
        }
      ]
    ],
    {{k, 1.0, "k"}, 0.1, 5.0, 0.1, Appearance -> "Labeled"},
    {{om, 0.5, "\[Omega]"}, -5.0, 5.0, 0.1, Appearance -> "Labeled"},
    Delimiter,
    {{Ck, 1.0, "Ck"}, 0.1, 5.0, 0.1, Appearance -> "Labeled"},
    {{eps, 1.0, "\[CurlyEpsilon]"}, 0.1, 5.0, 0.1, Appearance -> "Labeled"},
    {{uReg, 0.0, "uReg"}, 0.0, 1.0, 0.01, Appearance -> "Labeled"},
    Delimiter,
    {{k1Max, 20.0, "k1 cutoff"}, 2.0, 60.0, 1.0, Appearance -> "Labeled"},
    {{om1Max, 20.0, "\[Omega]1 cutoff"}, 2.0, 60.0, 1.0, Appearance -> "Labeled"},
    Delimiter,
    {{wp, 40, "WorkingPrecision"}, {20, 30, 40, 50}},
    {{ag, 8, "AccuracyGoal"}, {4, 6, 8, 10, 12}},
    {{pg, 8, "PrecisionGoal"}, {4, 6, 8, 10, 12}},
    {{mr, 15, "MaxRecursion"}, {8, 10, 12, 15, 20}},
    Delimiter,
    {{useAnalyticMu, False, "try analytic \[Mu]?"}, {False, True}},
    {{diagnostics, False, "print diagnostics?"}, {False, True}},
    {{progressEnabled, True, "print progress?"}, {True, False}},
    {{progressPrintStep, 0.01, "progress step (%)"}, 0.001, 1.0, 0.001},
    {{progressTarget, 1000000, "progress target"}, 10000, 5000000, 10000},
    {{progressMaxPrints, Infinity, "max prints"}, {Infinity, 1000, 5000, 10000}},
    {{showSample, True, "show sample integrand table?"}, {True, False}},
    TrackedSymbols :> {k, om, Ck, eps, uReg, k1Max, om1Max, wp, ag, pg, mr, useAnalyticMu, diagnostics, progressEnabled, progressPrintStep, progressTarget, progressMaxPrints, showSample}
  ];

